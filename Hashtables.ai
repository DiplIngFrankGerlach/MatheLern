  int SPHT_longlong_int::search(&longlong key,&int value)
  {
      var Hash_longlong hac;
      var Compare_longlong coac;
      var Assigner_longlong ak;
      var Assigner_int av;
      var int hc = hac.hash(key);
      var int m1 = -1;
      if( hc < 0 )
      {
        hc = hc * m1;
      } 
      var int pos = hc % _elements.sz;

      if(_elements[pos].is_used == 1)
      {
          if(coac.compare(key,_elements[pos].key) == 1)
          {
              av.assign(value,_elements[pos].value); 
              return 1;
          }
          else
          {
             var SPHT_Entry_longlong_int* entry = _elements[pos].next;
             while( entry != NULL )
             {
                if( coac.compare(entry.key,key) == 1 )
                {
                   av.assign(value,entry.value);
                   return 1;
                }
                entry = entry.next;
             }
             return 0;
          }
      }
      return 0;    
  }

