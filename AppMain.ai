//test

int Main::istPrim(int x)
{
   var int wurzel;
   var Math m;
   wurzel = cast(int,m.wurzel(x));

   for( var int i=2; i <= wurzel; i++)
   {
      var int rest = x % i;
      if(rest == 0) { return 0; }
   }
   return 1;
}


void Main::AdditionsTest()
{
   this.druckeMeldung("ZufaelligeAufgaben");
   var StarkerPseudoZufall spz;

   spz.initFromDevURandom();

   var String_16 sprPuffer;
   var int ende = 0;
   do
   {
     var int a = (spz.naechster() & 0xFFFFFF) % 51;
     var int b = (spz.naechster() & 0xFFFFFF) % 51;
     var int summe = a + b;
     pfc.fstr("$+$=?").sa(a).sa(b).pr();

     this.druckeMeldung("DrueckeEZumBeendenSonstLoesung");

     sprPuffer.clear();
     var Input input;
     input.getString(sprPuffer);  
     if(sprPuffer.equals("E") == 1) {ende = 1; }
     else
     {
        if(sprPuffer.asNumber() == summe )
        {
           this.druckeMeldung("Richtig");
        }
        else
        {
           this.druckeMeldung("Falsch");
        }
     }
     
   } 
   while(ende == 0);
}


void Main::MultTest()
{
   this.druckeMeldung("ZufaelligeAufgaben");
   var StarkerPseudoZufall spz;
   spz.initFromDevURandom();

   var String_16 sprPuffer;
   var int ende = 0;
   do
   {
     var int a = (spz.naechster() & 0xFFFFFF) % 10;
     var int b = (spz.naechster() & 0xFFFFFF) % 10;
     var int prod = a * b;
     pfc.fstr("$*$=?").sa(a).sa(b).pr();

     this.druckeMeldung("DrueckeEZumBeendenSonstLoesung");
     sprPuffer.clear();
     var Input input;
     input.getString(sprPuffer);  
     if(sprPuffer.equals("E") == 1) {ende = 1; }
     else
     {
        if(sprPuffer.asNumber() == prod )
        {
          this.druckeMeldung("Richtig");
        }
        else
        {
          this.druckeMeldung("Falsch");
        }
     }
     
   } 
   while(ende == 0);

}

void Main::Zehneruebergaenge()
{
   this.druckeMeldung("ZehnerUebergaenge");
   var StarkerPseudoZufall spz;
   spz.initFromDevURandom();
   for(var int i=2; i <= 9; i++)
   {
      var int summe;
      do {
         var int r = (spz.naechster() & 0xFFFFFF) % 10;
         r = r % 10;
         summe = i + r;
         if(summe > 10)
         { 
            var int rest = summe - 10;
            var int bis10 = 10 - i;
            pfc.fstr("$+$=$+$+$=$").sa(i).sa(r).sa(i).sa(bis10).sa(rest).sa(summe).pr();
         }
      }
      while( summe < 10);
   }
}


void Main::EinmaleinsMult()
{
   this.druckeMeldung("Das_kleine_Einmaleins_der_Multiplikation");
   for(var int i=0; i <= 20;i++)
   {
      for(var int j=0; j <= 20;j++)
      {
        var int produkt = i*j;
        pfc.fstr("$*$=$").sa(i).sa(j).sa(produkt).pr();
      }
   }
}

void Main::Erste100Primzahlen()
{
   this.druckeMeldung("Erste_100_Primzahlen");
   var int primAnzahl = 1;
   
   pfc.fstr("2").pr();

   var Main am;
   var int i=3;
   do
   {
      if(am.istPrim(i) == 1)
      {
         pfc.fstr("$").sa(i).pr();
         primAnzahl++;
      }
      i++;
   }
   while(primAnzahl < 100);
}

void Main::DivisionsTest()
{
   this.druckeMeldung("ZufaelligeAufgaben");
   var StarkerPseudoZufall spz;

   spz.initFromDevURandom();

   var String_16 sprPuffer;
   var int ende = 0;
   do
   {
     var int a = (spz.naechster() & 0xFFFFFF) % 30;
     var int b = (spz.naechster() & 0xFFFFFF) % 30;
     if(b == 0) { b = 1; }
     var int quotient = a / b;
     pfc.fstr("$/$=?").sa(a).sa(b).pr();

     this.druckeMeldung("DrueckeEZumBeendenSonstLoesung");
     sprPuffer.clear();
     var Input input;
     input.getString(sprPuffer);  
     if(sprPuffer.equals("E") == 1) {ende = 1; }
     else
     {
        if(sprPuffer.asNumber() == quotient )
        {
          this.druckeMeldung("Richtig");
        }
        else
        {
          this.druckeMeldung("Falsch");
        }
     }
     
   } 
   while(ende == 0);
}


void Main::InternerTest()
{
   var SPHT_STRP_STRP zahlZuZK;

   for(var longlong i=0; i < 100;i = i + 4)
   {
      var String_16* zk= new String_16("hans");
      zk.append(i);

      var String_16* schluessel = new String_16;
      schluessel.append("schl_");
      schluessel.append(i);

      zahlZuZK.insert(schluessel,zk);
   }
 
   var String_16* value = new String_16;
   var String_16* key=new String_16("schl_16");
   if(zahlZuZK.search(key,value) == 1) {pfc.fstr("gefunden: $").sa(value).pr(); }
   else {pfc.fstr("FEHLER").pr(); }

   key = new String_16("schl_17");
   if(zahlZuZK.search(key,value) == 1) {pfc.fstr("FEHLER 2").pr(); }

   var SPHT_STR_STR* htStS = new SPHT_STR_STR;

   var String_16 schluessel;
   var String_16 wert;
   schluessel.assign("Hund");
   wert.assign("Bello");
   htStS.insert(schluessel, wert); 
   schluessel.assign("Katze");
   wert.assign("Mia");
   htStS.insert(schluessel, wert); 

   var SPHT_STR_STR* htStS2 = new SPHT_STR_STR;

   schluessel.assign("Apfel");
   wert.assign("Elstar");
   htStS2.insert(schluessel, wert); 
   schluessel.assign("Birne");
   wert.assign("Emma");
   htStS2.insert(schluessel, wert); 

   var SPHT_STR_HTS htTop;
   schluessel.assign("Haustiere");
   htTop.insert(schluessel,htStS); 
   schluessel.assign("Fruechte");
   htTop.insert(schluessel,htStS2); 

   var SPHT_STR_STR* htRet;

   schluessel.assign("Haustiere");
   if(htTop.search(schluessel,htRet) != 1) { pfc.fstr("Fehler3").pr(); }
   else
   {
       schluessel.assign("Hund");
       wert.clear();
       if(htRet.search(schluessel,wert) != 1) { pfc.fstr("Fehler4").pr(); }
       if(wert.equals("Bello") != 1) { pfc.fstr("Fehler5").pr(); }
       pfc.fstr("Erfolg").pr();
   }
   

}

void Main::druckeMeldung(&char schluessel[])
{
   var String_16 meldung;
   mesm.findeMeldung(schluessel,meldung);
   pfc.pr(meldung);
}

int Main::main()
{ 
   /*
   */
 
   mesm = new MehrsprachigeMeldung;

   if(mesm.leseMeldungsDatei() == 1) 
   {
   } 
   else { pfc.pr("konnte Meldungsdatei nicht lesen"); return -1; }
 
   do{
     pfc.fstr("################################################################").pr();
     pfc.fstr("################################################################").pr();
     this.druckeMeldung("Waehle_aus");
     this.druckeMeldung("Additions_Test_Kommando");
     this.druckeMeldung("Multiplikations_Test_Kommando");
     this.druckeMeldung("Einmaleins_Test_Kommando");
     this.druckeMeldung("Erste_100_Primzahlen_Kommando");
     this.druckeMeldung("Zehneruebergaenge_Kommando");
     this.druckeMeldung("Division_Test_Kommando");
     pfc.pr("Interner Test=IT");
     this.druckeMeldung("Abbruch_Kommando");

     var Input inp;

     var String_16 eingabe;
     inp.getString(eingabe);
   

     if(eingabe.equals("AT")) { this.AdditionsTest(); }

     if(eingabe.equals("EM")) { this.EinmaleinsMult(); }

     if(eingabe.equals("EP")) { this.Erste100Primzahlen(); }

     if(eingabe.equals("ZU")) { this.Zehneruebergaenge(); }

     if(eingabe.equals("MT")) { this.MultTest(); }

     if(eingabe.equals("DT")) { this.DivisionsTest(); }

     if(eingabe.equals("IT")) { this.InternerTest(); }
   }
   while(1==1);
   
   return 1;
}

